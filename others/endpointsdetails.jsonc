{
  "Auth": {
    "POST /auth/login": {
      "description": "Login and return token",
      "request": {
        "headers": {},
        "body": {
          "userName": "string (required)",
          "password": "string (required)"
        }
      },
      "response": {
        "200": {
          "token": "string (JWT or session token)",
          "user": {
            "userId": "int",
            "userName": "string",
            "role": "int (ADMIN/CASHIER)"
          }
        },
        "401": "{ error: 'Invalid credentials' }"
      }
    },

    "POST /auth/logout": {
      "description": "Invalidate session/token",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "body": {}
      },
      "response": {
        "200": "{ message: 'Logged out successfully' }",
        "401": "{ error: 'Unauthorized' }"
      }
    },

    "GET /auth/me": {
      "description": "Get current logged-in user",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "body": {}
      },
      "response": {
        "200": {
          "userId": "int",
          "userName": "string",
          "phoneNumber": "string",
          "address": "string",
          "role": "int",
          "createdAt": "date"
        },
        "401": "{ error: 'Unauthorized' }"
      }
    }
  },

  "Users": {
    "GET /users": {
      "description": "List users",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "queryParams": {
          "page": "int (optional, default: 1)",
          "limit": "int (optional, default: 20)",
          "role": "int (optional, filter by ADMIN/CASHIER)",
          "search": "string (optional, search by userName or phoneNumber)"
        },
        "body": {}
      },
      "response": {
        "200": {
          "users": [
            {
              "userId": "int",
              "userName": "string",
              "phoneNumber": "string",
              "address": "string",
              "role": "int",
              "createdAt": "date"
            }
          ],
          "pagination": {
            "total": "int",
            "page": "int",
            "limit": "int"
          }
        }
      }
    },

    "POST /users": {
      "description": "Create user",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "body": {
          "userName": "string (required)",
          "password": "string (required, min length)",
          "phoneNumber": "string (optional)",
          "address": "string (optional)",
          "role": "int (required, ADMIN=1 / CASHIER=2)"
        }
      },
      "response": {
        "201": {
          "userId": "int",
          "userName": "string",
          "phoneNumber": "string",
          "address": "string",
          "role": "int",
          "createdAt": "date"
        },
        "400": "{ error: 'Validation error' }",
        "409": "{ error: 'Username already exists' }"
      }
    },

    "PUT /users/{id}": {
      "description": "Update user",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "pathParams": {
          "id": "int (userId)"
        },
        "body": {
          "userName": "string (optional)",
          "password": "string (optional, only if changing)",
          "phoneNumber": "string (optional)",
          "address": "string (optional)",
          "role": "int (optional)"
        }
      },
      "response": {
        "200": {
          "userId": "int",
          "userName": "string",
          "phoneNumber": "string",
          "address": "string",
          "role": "int",
          "updatedAt": "date"
        },
        "404": "{ error: 'User not found' }"
      }
    },

    "DELETE /users/{id}": {
      "description": "Delete user (soft delete)",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "pathParams": {
          "id": "int (userId)"
        },
        "body": {}
      },
      "response": {
        "200": "{ message: 'User deleted successfully' }",
        "404": "{ error: 'User not found' }"
      }
    }
  },

  "Medicines": {
    "GET /medicines": {
      "description": "List medicines",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "queryParams": {
          "page": "int (optional)",
          "limit": "int (optional)",
          "categoryId": "int (optional)",
          "isActive": "bool (optional)",
          "search": "string (optional, search by name or barcode)"
        },
        "body": {}
      },
      "response": {
        "200": {
          "medicines": [
            {
              "medicineId": "int",
              "name": "string",
              "arabicName": "string",
              "barcode": "string",
              "categoryId": "int",
              "unit": "string",
              "isActive": "bool",
              "createdAt": "date"
            }
          ],
          "pagination": {
            "total": "int",
            "page": "int",
            "limit": "int"
          }
        }
      }
    },

    "GET /medicines/{id}": {
      "description": "Get medicine details",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "pathParams": {
          "id": "int (medicineId)"
        },
        "body": {}
      },
      "response": {
        "200": {
          "medicineId": "int",
          "name": "string",
          "arabicName": "string",
          "barcode": "string",
          "categoryId": "int",
          "categoryName": "string",
          "unit": "string",
          "isActive": "bool",
          "createdAt": "date"
        },
        "404": "{ error: 'Medicine not found' }"
      }
    },

    "POST /medicines": {
      "description": "Create medicine",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "body": {
          "name": "string (required)",
          "arabicName": "string (optional)",
          "barcode": "string (required, must be unique)",
          "categoryId": "int (required)",
          "unit": "string (required, e.g., 'box', 'pill')"
        }
      },
      "response": {
        "201": {
          "medicineId": "int",
          "name": "string",
          "arabicName": "string",
          "barcode": "string",
          "categoryId": "int",
          "unit": "string",
          "isActive": "bool",
          "createdAt": "date"
        },
        "400": "{ error: 'Validation error' }",
        "409": "{ error: 'Barcode already exists' }"
      }
    },

    "PUT /medicines/{id}": {
      "description": "Update medicine",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "pathParams": {
          "id": "int (medicineId)"
        },
        "body": {
          "name": "string (optional)",
          "arabicName": "string (optional)",
          "barcode": "string (optional, must be unique)",
          "categoryId": "int (optional)",
          "unit": "string (optional)",
          "isActive": "bool (optional)"
        }
      },
      "response": {
        "200": {
          "medicineId": "int",
          "name": "string",
          "arabicName": "string",
          "barcode": "string",
          "categoryId": "int",
          "unit": "string",
          "isActive": "bool",
          "updatedAt": "date"
        },
        "404": "{ error: 'Medicine not found' }"
      }
    },

    "DELETE /medicines/{id}": {
      "description": "Deactivate medicine (soft delete)",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "pathParams": {
          "id": "int (medicineId)"
        },
        "body": {}
      },
      "response": {
        "200": "{ message: 'Medicine deactivated' }",
        "404": "{ error: 'Medicine not found' }"
      }
    },

    "GET /medicines/search?q=": {
      "description": "Search medicines by name or barcode (VERY IMPORTANT for POS)",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "queryParams": {
          "q": "string (required, search query - matches name, arabicName, or barcode)"
        },
        "body": {}
      },
      "response": {
        "200": {
          "medicines": [
            {
              "medicineId": "int",
              "name": "string",
              "arabicName": "string",
              "barcode": "string",
              "unit": "string",
              "currentStock": "int (aggregated from batches)"
            }
          ]
        }
      }
    }
  },

  "Categories": {
    "GET /categories": {
      "description": "List categories",
      "request": {
        "headers": {
          "Authorization": "Bearer {token}"
        },
        "queryParams": {
