# PharmaCore Backend - Environment Configuration Template
# Copy this file to '.env' and fill in your real values.
# IMPORTANT: Never commit '.env' to your repository.

# Database Connection (PostgreSQL)
# Format: Host=...;Port=...;Database=...;Username=...;Password=...
ConnectionStrings__Default="Host=localhost;Port=5432;Database=pharma_core;Username=postgres;Password=123"

# Security (JWT)
# Must be at least 32-64 characters long for HS256/HS512
Jwt__SecretKey="your-super-long-secure-development-key-2026-min-32-chars"

# Optional overrides
# ASPNETCORE_ENVIRONMENT=Development
